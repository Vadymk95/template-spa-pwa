# Optional nvm version switch (.nvmrc). Fenced with set +e: husky runs hooks
# under `sh -e`, and nvm re-arms errexit internally before returning non-zero —
# without the fence a missing nvm version kills the hook before its real work.
export NVM_DIR="${NVM_DIR:-$HOME/.nvm}"
if [ -s "$NVM_DIR/nvm.sh" ]; then
    set +e
    . "$NVM_DIR/nvm.sh" > /dev/null 2>&1
    nvm use --silent > /dev/null 2>&1
    set -e
fi

echo "→ verify (typecheck → lint → format → coverage → build → e2e)"
npm run verify || {
    echo "❌ verify failed. Fix before push."
    echo "   First-time Playwright browsers are installed by scripts/ensure-playwright.mjs"
    exit 1
}
