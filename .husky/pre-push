export NVM_DIR="${NVM_DIR:-$HOME/.nvm}"
[ -s "$NVM_DIR/nvm.sh" ] && . "$NVM_DIR/nvm.sh" && nvm use --silent 2>/dev/null || true

echo "→ format:check"
npm run format:check || { echo "❌ Formatting check failed. Run 'npm run format' and re-commit."; exit 1; }

echo "→ lint"
npm run lint || { echo "❌ Lint failed. Fix errors before push."; exit 1; }

echo "→ type-check"
npx tsc -b --noEmit || { echo "❌ TypeScript type-check failed. Fix errors before push."; exit 1; }
