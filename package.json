{
    "name": "react-spa-pwa-foundation",
    "private": true,
    "version": "3.1.0",
    "type": "module",
    "engines": {
        "node": ">=24.0.0",
        "npm": ">=10.0.0"
    },
    "scripts": {
        "dev": "vite",
        "build": "tsc -b && vite build",
        "build:analyze": "ANALYZE=true npm run build",
        "icons:placeholders": "node scripts/generate-placeholder-icons.mjs",
        "verify:pwa": "node scripts/check-pwa.mjs",
        "perf:ci": "lhci autorun",
        "verify:web-vitals-chunks": "node scripts/check-web-vitals-chunks.mjs",
        "verify:web-vitals-chunks:full": "node scripts/check-web-vitals-chunks.mjs --full",
        "size:check": "size-limit",
        "typecheck": "tsc -b",
        "lint": "eslint .",
        "lint:oxlint": "oxlint --config .oxlintrc.json .",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "lint:staged": "lint-staged",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "test:e2e": "playwright test",
        "test:e2e:ui": "playwright test --ui",
        "ci:local": "npm audit --audit-level=moderate && npm run typecheck && npm run lint:oxlint && npm run lint && npm run format:check && npm run test:coverage && npm run build && npm run verify:pwa && npm run verify:web-vitals-chunks && npm run size:check && npm run perf:ci && node scripts/ensure-playwright.mjs && PLAYWRIGHT_USE_PREVIEW=1 npm run test:e2e",
        "preview": "vite preview",
        "prepare": "husky"
    },
    "dependencies": {
        "@hookform/resolvers": "^5.4.0",
        "@radix-ui/react-slot": "^1.2.4",
        "@t3-oss/env-core": "^0.13.11",
        "@tanstack/react-query": "^5.100.13",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "i18next": "^26.2.0",
        "i18next-browser-languagedetector": "^8.2.1",
        "i18next-http-backend": "^4.0.0",
        "lucide-react": "^1.16.0",
        "react": "^19.2.6",
        "react-dom": "^19.2.6",
        "react-hook-form": "^7.76.0",
        "react-i18next": "^17.0.8",
        "react-router-dom": "^7.15.1",
        "tailwind-merge": "^3.6.0",
        "tw-animate-css": "^1.4.0",
        "web-vitals": "^5.2.0",
        "zod": "^4.4.3",
        "zustand": "^5.0.13"
    },
    "devDependencies": {
        "@axe-core/playwright": "^4.11.3",
        "@commitlint/cli": "^21.0.2",
        "@commitlint/config-conventional": "^21.0.2",
        "@eslint/js": "^9.39.4",
        "@lhci/cli": "^0.15.1",
        "@playwright/test": "^1.60.0",
        "@tailwindcss/vite": "^4.3.1",
        "@tanstack/eslint-plugin-query": "^5.101.0",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@testing-library/user-event": "^14.6.1",
        "@types/node": "^25.9.3",
        "@types/react": "^19.2.15",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^6.0.2",
        "@vitest/coverage-v8": "^4.1.8",
        "eslint": "^9.39.4",
        "eslint-config-prettier": "^10.1.8",
        "eslint-import-resolver-typescript": "^4.4.5",
        "eslint-plugin-import-x": "^4.16.2",
        "eslint-plugin-jsx-a11y": "^6.10.2",
        "eslint-plugin-oxlint": "^1.69.0",
        "eslint-plugin-prettier": "^5.5.6",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-hooks": "^7.1.1",
        "eslint-plugin-react-refresh": "^0.5.3",
        "globals": "^17.6.0",
        "husky": "^9.1.7",
        "jsdom": "^29.1.1",
        "lint-staged": "^17.0.7",
        "msw": "^2.14.6",
        "oxlint": "^1.66.0",
        "prettier": "^3.8.4",
        "rollup-plugin-visualizer": "^7.0.1",
        "size-limit": "^12.1.0",
        "@size-limit/preset-app": "^12.1.0",
        "tailwindcss": "^4.3.0",
        "typescript": "~6.0.3",
        "typescript-eslint": "^8.61.0",
        "vite": "^8.0.16",
        "vite-plugin-compression": "^0.5.1",
        "vite-plugin-pwa": "^1.3.0",
        "vite-plugin-webfont-dl": "^3.12.0",
        "vitest": "^4.1.7"
    },
    "overrides": {
        "qs": ">=6.15.2",
        "serialize-javascript": ">=7.0.5",
        "tmp": ">=0.2.4",
        "uuid": ">=13.0.1",
        "ws": ">=8.21.0"
    },
    "lint-staged": {
        "*.{ts,tsx,js,jsx}": [
            "oxlint --config .oxlintrc.json --fix",
            "eslint --fix",
            "prettier --write"
        ],
        "*.{json,md,yml,yaml}": [
            "prettier --write"
        ]
    }
}
