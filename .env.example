# Environment Variables Template
# Copy this file to .env and fill in your values.
#
# ⚠️ SECURITY: every VITE_* variable is BAKED INTO THE PUBLIC BUNDLE.
# Never put secrets here (Stripe / Firebase admin / API keys with write scope).
# `import.meta.env.VITE_*` is readable in DevTools → Sources for any visitor.
# Server-only secrets must live on your backend / edge function, never in this file.

# Backend API base URL — example template seed; remove if you go BaaS-SDK-only (Supabase / Firebase).
# VITE_API_URL=https://api.example.com

# Web Vitals: true = load `web-vitals/attribution` chunk (richer metric payloads).
# Default false; bumps initial bundle by ~3 KB brotli.
# VITE_WEB_VITALS_ATTRIBUTION=false

# DEV-only MSW browser worker (mocks fetches via public/mockServiceWorker.js).
# Default false; flip to true when working without a real backend in dev.
# VITE_ENABLE_MSW=false
