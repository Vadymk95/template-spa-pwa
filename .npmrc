# Lifecycle scripts are disabled repo-wide: install-script malware is the
# primary npm supply-chain vector (npm v12 skips them by default; this covers
# npm 10/11 users too). After cloning, install git hooks once with:
#   npm run prepare
ignore-scripts=true

# Resolve only package versions released >=3 days ago (npm 11.10+; value is in
# DAYS — pnpm's equivalent uses minutes, don't copy values across). Older npm
# warns and ignores the key. Urgent patch or brand-new package:
#   npm install <pkg> --min-release-age=0
min-release-age=3
